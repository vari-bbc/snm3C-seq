name: mapping
channels:
  - conda-forge
  - bioconda
  - defaults
dependencies:
  - python=3.7
  - pip
  - jupyter
  - jupyterlab_code_formatter
  - cutadapt=2.10
  - snakemake=5.17
  - bismark=0.20
  - samtools=1.15
  - picard=2.27.5
  - bedtools=2.29
  - star=2.7.3a
  - subread=2.0
  - hisat-3n=0.0.3
  - bowtie2=2.3
  - bowtie=1.3
  - htslib=1.15
  - pysam=0.19
  - pytables
  - seaborn
  - matplotlib
  - pip:
    - papermill
    - cemba-data
    - allcools
    - webcolors<1.12
